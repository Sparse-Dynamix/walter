DEPLOY_MODE=dev
PRODUCT_NAME=My API
PRODUCT_SLUG=my-api
SENDER_DOMAIN=yourdomain.com
SHOPIFY_STORE=your-store.myshopify.com
# From: shopify app env show --config shopify.app.dev.toml (SHOPIFY_API_SECRET)
SHOPIFY_WEBHOOK_SECRET=
# Optional; defaults to noreply@${SENDER_DOMAIN}
SENDER_EMAIL=noreply@yourdomain.com
DYNAMODB_ENDPOINT=http://localhost:8000
SES_ENDPOINT=http://localhost:8005
AWS_REGION=us-east-1
STOREFRONT_SHOPIFY_SETUP=1
